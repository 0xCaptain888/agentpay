# =============================================================================
# AgentPay Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set. Variables marked [OPTIONAL] have
# sensible defaults and can be omitted.

# -----------------------------------------------------------------------------
# Chain
# -----------------------------------------------------------------------------

# [OPTIONAL] Solana RPC endpoint. Defaults to public devnet if not set.
RPC_URL=https://api.devnet.solana.com

# [REQUIRED] AgentVault program ID deployed on-chain.
PROGRAM_ID=<your-program-id-after-anchor-deploy>

# [OPTIONAL] USDC mint address (devnet). Only change if using a custom mint.
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# [OPTIONAL] Public key of the vault's associated token account (for example-api).
VAULT_ATA=<your-vault-ata-after-init>

# -----------------------------------------------------------------------------
# Agent
# -----------------------------------------------------------------------------

# [REQUIRED] Path to the agent's Solana keypair JSON file.
AGENT_KEYPAIR_PATH=./agent-keypair.json

# [OPTIONAL] Keypair byte array as JSON string — takes priority over AGENT_KEYPAIR_PATH.
# Use this for cloud deployments (Railway, etc.) instead of mounting a file.
# Example: AGENT_KEYPAIR_JSON=[12,34,56,...]
# AGENT_KEYPAIR_JSON=

# [OPTIONAL] Price charged per signal in USDC lamports (6 decimals). Default: 10000 = 0.01 USDC.
PRICE_PER_SIGNAL=10000

# [OPTIONAL] Port for the example API server. Default: 3001.
PORT=3001

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible API)
# -----------------------------------------------------------------------------

# [REQUIRED] API key for the LLM provider (OpenAI, DeepSeek, etc.)
OPENAI_API_KEY=sk-your-api-key-here

# [OPTIONAL] Base URL override for non-OpenAI providers (e.g. DeepSeek)
OPENAI_API_BASE=https://api.deepseek.com

# [OPTIONAL] Model name. Default: gpt-4o-mini.
LLM_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# Supplier USDC ATAs (for autonomous spending)
# Run scripts/setup-vendors.sh to generate these.
# -----------------------------------------------------------------------------

SUPPLIER_USDC_ATA_OPENAI=<vendor-ata-address>
SUPPLIER_USDC_ATA_RPC=<vendor-ata-address>
SUPPLIER_USDC_ATA_TWITTER=<vendor-ata-address>

# -----------------------------------------------------------------------------
# Twitter (all optional — only needed for social posting features)
# -----------------------------------------------------------------------------

# TWITTER_BEARER_TOKEN=your-twitter-bearer-token
# TWITTER_CONSUMER_KEY=your-consumer-key
# TWITTER_CONSUMER_SECRET=your-consumer-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# -----------------------------------------------------------------------------
# Dashboard (Next.js)
# -----------------------------------------------------------------------------

# [OPTIONAL] URL of the AlphaScout API the dashboard connects to.
ALPHASCOUT_URL=http://localhost:8000

# [OPTIONAL] Program ID exposed to the browser for on-chain queries.
NEXT_PUBLIC_PROGRAM_ID=<same-as-PROGRAM_ID>

# [OPTIONAL] Agent's vault authority public key exposed to the browser.
NEXT_PUBLIC_VAULT_AUTHORITY=<agent-pubkey>

# [OPTIONAL] Vault PDA and USDC ATA (for Dashboard footer links).
NEXT_PUBLIC_VAULT_PDA=<vault-pda-after-init>
NEXT_PUBLIC_VAULT_ATA=<vault-ata-after-init>
